<Window x:Class="Havyn.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cefSharp="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
        Title="Havyn"
        Width="1500"
        Height="940"
        MinWidth="1180"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#050507"
        Icon="Assets/havyn-icon.ico">
    <Window.Resources>
        <DataTemplate x:Key="ParticipantTileYouTemplate">
            <Border Style="{StaticResource VideoTileStyle}">
                <Grid>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF232530" Offset="0" />
                                <GradientStop Color="#FF0D0E12" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <TextBlock Text="You" Style="{StaticResource BubbleLabelStyle}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8">
                        <Button Style="{StaticResource MiniButton}" Content="Mic" />
                        <Button Style="{StaticResource MiniButton}" Content="Cam" Margin="5,0,0,0" />
                        <Slider Width="92" Minimum="0" Maximum="100" Value="72" Margin="8,0,0,0" />
                    </StackPanel>
                    <Ellipse Width="9" Height="9" Fill="#FF4DFB79" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,9,9,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ParticipantTileAuenTemplate">
            <Border Style="{StaticResource VideoTileStyle}">
                <Grid>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF191B23" Offset="0" />
                                <GradientStop Color="#FF08090D" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <TextBlock Text="Auen" Style="{StaticResource BubbleLabelStyle}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8">
                        <Button Style="{StaticResource MiniButton}" Content="Mic" />
                        <Button Style="{StaticResource MiniButton}" Content="Cam" Margin="5,0,0,0" />
                        <Slider Width="92" Minimum="0" Maximum="100" Value="58" Margin="8,0,0,0" />
                    </StackPanel>
                    <Ellipse Width="9" Height="9" Fill="#FF4DFB79" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,9,9,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ChatContentTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="Chat" FontSize="18" FontWeight="Bold" />
                    <Button HorizontalAlignment="Right" Style="{StaticResource MiniButton}" Content="^" />
                </Grid>
                <StackPanel Grid.Row="1" Margin="0,12,0,12">
                    <Border Style="{StaticResource MessageStyle}">
                        <StackPanel>
                            <TextBlock Text="Havyn" Foreground="{StaticResource BlueBrush}" FontSize="11" FontWeight="Bold" />
                            <TextBlock Text="Treasure joined the room" FontSize="14" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MessageStyle}" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="Auen" Foreground="{StaticResource BlueBrush}" FontSize="11" FontWeight="Bold" />
                            <TextBlock Text="Ready when you are" FontSize="14" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="46" />
                    </Grid.ColumnDefinitions>
                    <TextBox Height="42"
                             VerticalContentAlignment="Center"
                             Background="#AA191A21"
                             BorderBrush="#24FFFFFF"
                             Foreground="{StaticResource InkBrush}"
                             Padding="12,0"
                             Text="Message the room..." />
                    <Button Grid.Column="1" Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="Send" />
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ParticipantsContentTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Button x:Name="ParticipantsToggle"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="ToggleParticipants_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="People" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="2"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,14,0" />
                        <TextBlock x:Name="ParticipantsChevron"
                                   Grid.Column="2"
                                   Text="v"
                                   FontSize="16"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <ScrollViewer x:Name="ParticipantsList"
                              Grid.Row="1"
                              MaxHeight="260"
                              Margin="0,12,0,0"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="Collapsed">
                    <StackPanel>
                        <Border Style="{StaticResource MessageStyle}" Margin="0,0,0,8">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="You" FontSize="14" FontWeight="Bold" />
                                    <TextBlock Text="Online - host" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                                </StackPanel>
                                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="Host" Foreground="{StaticResource BlueBrush}" FontSize="12" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource MessageStyle}">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Auen" FontSize="14" FontWeight="Bold" />
                                    <TextBlock Text="Online - ready" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                                </StackPanel>
                                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="Ready" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="MediaSourceTemplate">
            <Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="SOURCE"
                                       FontSize="10"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="Bold" />
                            <TextBlock x:Name="MediaStatusPill"
                                       Text="Searching"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BlueBrush}"
                                       Margin="10,0,0,0" />
                        </StackPanel>
                        <TextBlock x:Name="MediaSourceStateText"
                                   Text="Looking for media"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0" />
                        <TextBlock x:Name="MediaSourceHintText"
                                   Text="Open a video page. Havyn will detect a playable source here."
                                   FontSize="12"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,3,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="SyncSourceButton"
                                Content="Sync source"
                                MinWidth="128"
                                IsEnabled="False"
                                Opacity="0.5"
                                Click="SyncSource_Click"
                                ToolTip="Sync the detected source to the room" />
                        <Button Style="{StaticResource IconButton}" Margin="10,0,0,0" Content="⛶" Click="Fullscreen_Click" ToolTip="Enter fullscreen" />
                    </StackPanel>
                </Grid>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="Root" ClipToBounds="True">
        <Grid.Background>
            <RadialGradientBrush Center="0.78,0.08" RadiusX="0.9" RadiusY="0.8">
                <GradientStop Color="#441B0F17" Offset="0" />
                <GradientStop Color="#120B0B0F" Offset="0.52" />
                <GradientStop Color="#FF050507" Offset="1" />
            </RadialGradientBrush>
        </Grid.Background>

        <Grid x:Name="StandardOverlay" Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition Height="86" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource GlassPanelStyle}" MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
                <Grid Margin="12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44"
                                Height="44"
                                CornerRadius="22"
                                Background="#FFFFFFFF"
                                Padding="6">
                            <Image Source="Assets/havyn-mark.png" Stretch="Uniform" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Movie Night" FontSize="18" FontWeight="Bold" />
                            <TextBlock x:Name="MediaTitleText"
                                       Text="Open a video page"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button MinWidth="52" Content="🔗" ToolTip="Copy room link" />
                        <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="2" ToolTip="Participants" />
                        <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="⚙" ToolTip="Room settings" />
                        <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="—" Click="Minimize_Click" ToolTip="Minimize" />
                        <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="×" Click="Close_Click" ToolTip="Close" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="620" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="390" MinWidth="300" MaxWidth="560" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,14,18,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="320" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource GlassPanelStyle}" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource IconButton}" Content="←" Click="Back_Click" ToolTip="Back" />
                            <Button Grid.Column="1" Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="→" Click="Forward_Click" ToolTip="Forward" />
                            <Button Grid.Column="2" Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="↻" Click="Reload_Click" ToolTip="Reload" />
                            <TextBox x:Name="AddressBox"
                                     Grid.Column="3"
                                     Height="42"
                                     Margin="8,0"
                                     VerticalContentAlignment="Center"
                                     Background="#DD17181E"
                                     BorderBrush="#34FFFFFF"
                                     Foreground="{StaticResource InkBrush}"
                                     CaretBrush="{StaticResource InkBrush}"
                                     FontSize="15"
                                     Padding="14,0"
                                     KeyDown="AddressBox_KeyDown"
                                     Text="https://interactive-examples.mdn.mozilla.net/pages/tabbed/video.html" />
                            <Button Grid.Column="4" Style="{StaticResource IconButton}" Content="↵" Click="Load_Click" ToolTip="Open URL" />
                            <Button x:Name="AdBlockButton"
                                    Grid.Column="5"
                                    Style="{StaticResource IconButton}"
                                    Margin="8,0,0,0"
                                    Content="🛡"
                                    Click="ToggleAdBlock_Click"
                                    ToolTip="Ad blocker on" />
                        </Grid>
                    </Border>

                    <Border x:Name="StandardBrowserFrame"
                            Grid.Row="1"
                            Margin="0,14,0,0"
                            CornerRadius="18"
                            ClipToBounds="True"
                            Background="#FF050507"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1">
                        <Grid x:Name="StandardBrowserHost">
                            <cefSharp:ChromiumWebBrowser x:Name="Browser"
                                                         Address="https://interactive-examples.mdn.mozilla.net/pages/tabbed/video.html"
                                                         FrameLoadEnd="Browser_FrameLoadEnd"
                                                         LoadingStateChanged="Browser_LoadingStateChanged" />
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="1"
                              Width="8"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="#08FFFFFF"
                              ShowsPreview="True" />

                <Grid Grid.Column="2" Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="260" MinHeight="170" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" MinHeight="190" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource GlassPanelStyle}" Padding="12">
                        <StackPanel>
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Call" FontSize="18" FontWeight="Bold" />
                                    <TextBlock Text="Connected" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Grid" Width="58" Height="34" />
                                    <Button Content="Focus" Width="64" Height="34" Margin="6,0,0,0" />
                                </StackPanel>
                            </Grid>
                            <UniformGrid Rows="2" Columns="1" Margin="0,14,0,0">
                                <ContentControl Content="tile" ContentTemplate="{StaticResource ParticipantTileYouTemplate}" Margin="0,0,0,10" />
                                <ContentControl Content="tile" ContentTemplate="{StaticResource ParticipantTileAuenTemplate}" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <GridSplitter Grid.Row="1"
                                  Height="8"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="#08FFFFFF"
                                  ShowsPreview="True" />

                    <Border Grid.Row="2" Style="{StaticResource GlassPanelStyle}" Padding="14">
                        <ContentControl Content="chat" ContentTemplate="{StaticResource ChatContentTemplate}" />
                    </Border>

                    <Border Grid.Row="3" Style="{StaticResource GlassPanelStyle}" Margin="0,16,0,0" Padding="14">
                        <ContentControl Content="participants" ContentTemplate="{StaticResource ParticipantsContentTemplate}" />
                    </Border>
                </Grid>
            </Grid>

            <GridSplitter Grid.Row="2"
                          Height="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#08FFFFFF"
                          ShowsPreview="True" />

            <Border Grid.Row="3" Style="{StaticResource GlassPanelStyle}" VerticalAlignment="Bottom" Padding="16,10">
                <ContentControl Content="source" ContentTemplate="{StaticResource MediaSourceTemplate}" />
            </Border>
        </Grid>

        <Grid x:Name="FullscreenOverlay" Visibility="Collapsed" Opacity="0">
            <Grid x:Name="FullscreenBrowserHost" Background="#FF020204" />

            <Border x:Name="CinemaShade" IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#26000000" Offset="0" />
                        <GradientStop Color="#00000000" Offset="0.45" />
                        <GradientStop Color="#82000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Border IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#84000000" Offset="0" />
                        <GradientStop Color="#08000000" Offset="0.28" />
                        <GradientStop Color="#00000000" Offset="0.55" />
                        <GradientStop Color="#8A000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid x:Name="FullscreenHud" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource GlassPanelStyle}" Padding="8" MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource IconButton}" Content="↙" Click="Fullscreen_Click" ToolTip="Exit fullscreen" />
                            <StackPanel Margin="12,0,18,0" VerticalAlignment="Center">
                                <TextBlock Text="The WONDERfools" FontSize="12" FontWeight="Bold" />
                                <TextBlock x:Name="FullscreenMediaTitleText" Text="S1:E6 The WONDERfools" FontSize="10" Foreground="{StaticResource MutedBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource GlassPanelStyle}" Padding="8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="🔗" MinWidth="52" ToolTip="Copy room link" />
                            <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="2" ToolTip="Participants" />
                            <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="⚙" ToolTip="Settings" />
                            <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="↙" Click="Fullscreen_Click" ToolTip="Exit fullscreen" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Canvas Grid.RowSpan="3" x:Name="BubbleCanvas" ClipToBounds="False">
                    <Border x:Name="BubbleYou"
                            Width="276"
                            Height="158"
                            Style="{StaticResource FloatingBubbleStyle}"
                            Canvas.Left="1110"
                            Canvas.Top="76"
                            MouseLeftButtonDown="Bubble_MouseLeftButtonDown"
                            MouseMove="Bubble_MouseMove"
                            MouseLeftButtonUp="Bubble_MouseLeftButtonUp">
                        <Grid>
                            <ContentControl Content="tile" ContentTemplate="{StaticResource ParticipantTileYouTemplate}" />
                            <Rectangle x:Name="ResizeYou"
                                       Width="18"
                                       Height="18"
                                       Fill="#55FFFFFF"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Cursor="SizeNWSE"
                                       MouseLeftButtonDown="Resize_MouseLeftButtonDown"
                                       MouseMove="Resize_MouseMove"
                                       MouseLeftButtonUp="Resize_MouseLeftButtonUp" />
                        </Grid>
                    </Border>
                    <Border x:Name="BubbleAuen"
                            Width="276"
                            Height="158"
                            Style="{StaticResource FloatingBubbleStyle}"
                            Canvas.Left="1110"
                            Canvas.Top="250"
                            MouseLeftButtonDown="Bubble_MouseLeftButtonDown"
                            MouseMove="Bubble_MouseMove"
                            MouseLeftButtonUp="Bubble_MouseLeftButtonUp">
                        <Grid>
                            <ContentControl Content="tile" ContentTemplate="{StaticResource ParticipantTileAuenTemplate}" />
                            <Rectangle x:Name="ResizeAuen"
                                       Width="18"
                                       Height="18"
                                       Fill="#55FFFFFF"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Cursor="SizeNWSE"
                                       MouseLeftButtonDown="Resize_MouseLeftButtonDown"
                                       MouseMove="Resize_MouseMove"
                                       MouseLeftButtonUp="Resize_MouseLeftButtonUp" />
                        </Grid>
                    </Border>
                </Canvas>

                <Border x:Name="FullscreenChat"
                        Grid.RowSpan="3"
                        Width="374"
                        Height="218"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,12,76"
                        Opacity="0"
                        Style="{StaticResource ChatOverlayStyle}"
                        MouseEnter="ChatOverlay_MouseEnter"
                        MouseLeave="ChatOverlay_MouseLeave">
                    <ContentControl Content="chat" ContentTemplate="{StaticResource ChatContentTemplate}" />
                </Border>

                <Border Grid.Row="2"
                        Width="660"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource GlassPanelStyle}"
                        Padding="14,10"
                        Margin="0,0,0,0">
                    <ContentControl Content="source" ContentTemplate="{StaticResource MediaSourceTemplate}" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
