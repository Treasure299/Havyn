<Window x:Class="Havyn.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cefSharp="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
        Title="Havyn"
        Width="1500"
        Height="940"
        MinWidth="1180"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#050507"
        Icon="Assets/havyn-icon.ico">
    <Window.Resources>
        <DataTemplate x:Key="ParticipantTileYouTemplate">
            <Border Style="{StaticResource VideoTileStyle}">
                <Grid>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF232530" Offset="0" />
                                <GradientStop Color="#FF0D0E12" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <TextBlock Text="You" Style="{StaticResource BubbleLabelStyle}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8">
                        <Button Style="{StaticResource MiniButton}" Content="Mic" />
                        <Button Style="{StaticResource MiniButton}" Content="Cam" Margin="5,0,0,0" />
                        <Slider Width="92" Minimum="0" Maximum="100" Value="72" Margin="8,0,0,0" />
                    </StackPanel>
                    <Ellipse Width="9" Height="9" Fill="#FF4DFB79" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,9,9,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ParticipantTileAuenTemplate">
            <Border Style="{StaticResource VideoTileStyle}">
                <Grid>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF191B23" Offset="0" />
                                <GradientStop Color="#FF08090D" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <TextBlock Text="Auen" Style="{StaticResource BubbleLabelStyle}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8">
                        <Button Style="{StaticResource MiniButton}" Content="Mic" />
                        <Button Style="{StaticResource MiniButton}" Content="Cam" Margin="5,0,0,0" />
                        <Slider Width="92" Minimum="0" Maximum="100" Value="58" Margin="8,0,0,0" />
                    </StackPanel>
                    <Ellipse Width="9" Height="9" Fill="#FF4DFB79" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,9,9,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ChatContentTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="Chat" FontSize="18" FontWeight="Bold" />
                    <Button HorizontalAlignment="Right" Style="{StaticResource MiniButton}" Content="^" />
                </Grid>
                <StackPanel Grid.Row="1" Margin="0,12,0,12">
                    <Border Style="{StaticResource MessageStyle}">
                        <StackPanel>
                            <TextBlock Text="Havyn" Foreground="{StaticResource BlueBrush}" FontSize="11" FontWeight="Bold" />
                            <TextBlock Text="Treasure joined the room" FontSize="14" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MessageStyle}" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="Auen" Foreground="{StaticResource BlueBrush}" FontSize="11" FontWeight="Bold" />
                            <TextBlock Text="Ready when you are" FontSize="14" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="46" />
                    </Grid.ColumnDefinitions>
                    <TextBox Height="42"
                             VerticalContentAlignment="Center"
                             Background="#AA191A21"
                             BorderBrush="#24FFFFFF"
                             Foreground="{StaticResource InkBrush}"
                             Padding="12,0"
                             Text="Message the room..." />
                    <Button Grid.Column="1" Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="Send" />
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="PlaybackStripTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Slider x:Name="ProgressSlider"
                        Minimum="0"
                        Maximum="100"
                        Value="38"
                        VerticalAlignment="Center" />
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Width="62" Content="Play" Click="PlayPause_Click" />
                    <Button Grid.Column="1" Style="{StaticResource IconButton}" Margin="10,0,0,0" Content="-10" Click="BackTen_Click" />
                    <Button Grid.Column="2" Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="+10" Click="ForwardTen_Click" />
                    <TextBlock x:Name="PlaybackTimeText"
                               Grid.Column="3"
                               Text="40:04 / 1:17:36"
                               VerticalAlignment="Center"
                               Margin="18,0"
                               Foreground="{StaticResource InkBrush}" />
                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <Button Content="Sync source" MinWidth="128" />
                        <Button Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Content="First Sync Play" Click="FirstSyncPlay_Click" />
                        <Button Style="{StaticResource IconButton}" Margin="10,0,0,0" Content="Full" Click="Fullscreen_Click" />
                    </StackPanel>
                </Grid>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="Root" ClipToBounds="True">
        <Grid.Background>
            <RadialGradientBrush Center="0.78,0.08" RadiusX="0.9" RadiusY="0.8">
                <GradientStop Color="#441B0F17" Offset="0" />
                <GradientStop Color="#120B0B0F" Offset="0.52" />
                <GradientStop Color="#FF050507" Offset="1" />
            </RadialGradientBrush>
        </Grid.Background>

        <Grid x:Name="StandardOverlay" Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
                <RowDefinition Height="86" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource GlassPanelStyle}" MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
                <Grid Margin="12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Assets/havyn-logo.png" Width="44" Height="44" Stretch="Uniform" />
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Movie Night" FontSize="18" FontWeight="Bold" />
                            <TextBlock x:Name="MediaTitleText"
                                       Text="Open a video page"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Style="{StaticResource IconButton}" Content="-10" Click="BackTen_Click" />
                        <Button x:Name="CenterPlayButton" Width="48" Height="42" Margin="8,0" Content="Play" Click="PlayPause_Click" />
                        <Button Style="{StaticResource IconButton}" Content="+10" Click="ForwardTen_Click" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button MinWidth="112" Content="Room link" />
                        <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="2" />
                        <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="Set" />
                        <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="Min" Click="Minimize_Click" />
                        <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="Close" Click="Close_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="390" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,14,18,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource GlassPanelStyle}" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource IconButton}" Content="Back" Click="Back_Click" />
                            <Button Grid.Column="1" Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="Next" Click="Forward_Click" />
                            <TextBox x:Name="AddressBox"
                                     Grid.Column="2"
                                     Height="42"
                                     Margin="8,0"
                                     VerticalContentAlignment="Center"
                                     Background="#DD17181E"
                                     BorderBrush="#34FFFFFF"
                                     Foreground="{StaticResource InkBrush}"
                                     CaretBrush="{StaticResource InkBrush}"
                                     FontSize="15"
                                     Padding="14,0"
                                     KeyDown="AddressBox_KeyDown"
                                     Text="https://interactive-examples.mdn.mozilla.net/pages/tabbed/video.html" />
                            <Button Grid.Column="3" Style="{StaticResource IconButton}" Content="Go" Click="Load_Click" />
                        </Grid>
                    </Border>

                    <Border x:Name="StandardBrowserFrame"
                            Grid.Row="1"
                            Margin="0,14,0,0"
                            CornerRadius="18"
                            ClipToBounds="True"
                            Background="#FF050507"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1">
                        <Grid x:Name="StandardBrowserHost">
                            <cefSharp:ChromiumWebBrowser x:Name="Browser"
                                                         Address="https://interactive-examples.mdn.mozilla.net/pages/tabbed/video.html"
                                                         FrameLoadEnd="Browser_FrameLoadEnd"
                                                         LoadingStateChanged="Browser_LoadingStateChanged" />
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,96,0,0">
                    <Border Style="{StaticResource GlassPanelStyle}" Padding="12">
                        <StackPanel>
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Call" FontSize="18" FontWeight="Bold" />
                                    <TextBlock Text="Connected" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Grid" Width="58" Height="34" />
                                    <Button Content="Focus" Width="64" Height="34" Margin="6,0,0,0" />
                                </StackPanel>
                            </Grid>
                            <UniformGrid Rows="2" Columns="1" Margin="0,14,0,0">
                                <ContentControl Content="tile" ContentTemplate="{StaticResource ParticipantTileYouTemplate}" Margin="0,0,0,10" />
                                <ContentControl Content="tile" ContentTemplate="{StaticResource ParticipantTileAuenTemplate}" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GlassPanelStyle}" Margin="0,18,0,0" Padding="14">
                        <ContentControl Content="chat" ContentTemplate="{StaticResource ChatContentTemplate}" />
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource GlassPanelStyle}" VerticalAlignment="Bottom" Padding="16,10">
                <ContentControl Content="playback" ContentTemplate="{StaticResource PlaybackStripTemplate}" />
            </Border>
        </Grid>

        <Grid x:Name="FullscreenOverlay" Visibility="Collapsed" Opacity="0">
            <Grid x:Name="FullscreenBrowserHost" Background="#FF020204" />

            <Border x:Name="CinemaShade" IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#26000000" Offset="0" />
                        <GradientStop Color="#00000000" Offset="0.45" />
                        <GradientStop Color="#82000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Border IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#84000000" Offset="0" />
                        <GradientStop Color="#08000000" Offset="0.28" />
                        <GradientStop Color="#00000000" Offset="0.55" />
                        <GradientStop Color="#8A000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid x:Name="FullscreenHud" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource GlassPanelStyle}" Padding="8" MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource IconButton}" Content="Exit" Click="Fullscreen_Click" />
                            <StackPanel Margin="12,0,18,0" VerticalAlignment="Center">
                                <TextBlock Text="The WONDERfools" FontSize="12" FontWeight="Bold" />
                                <TextBlock x:Name="FullscreenMediaTitleText" Text="S1:E6 The WONDERfools" FontSize="10" Foreground="{StaticResource MutedBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource GlassPanelStyle}" Padding="8" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource IconButton}" Content="-10" Click="BackTen_Click" />
                            <Button x:Name="FullscreenPlayButton" Width="48" Height="42" Margin="8,0" Content="Play" Click="PlayPause_Click" />
                            <Button Style="{StaticResource IconButton}" Content="+10" Click="ForwardTen_Click" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource GlassPanelStyle}" Padding="8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Room link" MinWidth="108" />
                            <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="2" />
                            <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="Set" />
                            <Button Style="{StaticResource IconButton}" Margin="8,0,0,0" Content="Full" Click="Fullscreen_Click" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Canvas Grid.RowSpan="3" x:Name="BubbleCanvas" ClipToBounds="False">
                    <Border x:Name="BubbleYou"
                            Width="276"
                            Height="158"
                            Style="{StaticResource FloatingBubbleStyle}"
                            Canvas.Left="1110"
                            Canvas.Top="76"
                            MouseLeftButtonDown="Bubble_MouseLeftButtonDown"
                            MouseMove="Bubble_MouseMove"
                            MouseLeftButtonUp="Bubble_MouseLeftButtonUp">
                        <Grid>
                            <ContentControl Content="tile" ContentTemplate="{StaticResource ParticipantTileYouTemplate}" />
                            <Rectangle x:Name="ResizeYou"
                                       Width="18"
                                       Height="18"
                                       Fill="#55FFFFFF"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Cursor="SizeNWSE"
                                       MouseLeftButtonDown="Resize_MouseLeftButtonDown"
                                       MouseMove="Resize_MouseMove"
                                       MouseLeftButtonUp="Resize_MouseLeftButtonUp" />
                        </Grid>
                    </Border>
                    <Border x:Name="BubbleAuen"
                            Width="276"
                            Height="158"
                            Style="{StaticResource FloatingBubbleStyle}"
                            Canvas.Left="1110"
                            Canvas.Top="250"
                            MouseLeftButtonDown="Bubble_MouseLeftButtonDown"
                            MouseMove="Bubble_MouseMove"
                            MouseLeftButtonUp="Bubble_MouseLeftButtonUp">
                        <Grid>
                            <ContentControl Content="tile" ContentTemplate="{StaticResource ParticipantTileAuenTemplate}" />
                            <Rectangle x:Name="ResizeAuen"
                                       Width="18"
                                       Height="18"
                                       Fill="#55FFFFFF"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Cursor="SizeNWSE"
                                       MouseLeftButtonDown="Resize_MouseLeftButtonDown"
                                       MouseMove="Resize_MouseMove"
                                       MouseLeftButtonUp="Resize_MouseLeftButtonUp" />
                        </Grid>
                    </Border>
                </Canvas>

                <Border x:Name="FullscreenChat"
                        Grid.RowSpan="3"
                        Width="374"
                        Height="218"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,12,76"
                        Opacity="0"
                        Style="{StaticResource ChatOverlayStyle}"
                        MouseEnter="ChatOverlay_MouseEnter"
                        MouseLeave="ChatOverlay_MouseLeave">
                    <ContentControl Content="chat" ContentTemplate="{StaticResource ChatContentTemplate}" />
                </Border>

                <Border Grid.Row="2"
                        Width="660"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource GlassPanelStyle}"
                        Padding="14,10"
                        Margin="0,0,0,0">
                    <ContentControl Content="playback" ContentTemplate="{StaticResource PlaybackStripTemplate}" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
